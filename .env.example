# baby-pool environment — copy to .env on the box and fill in.
# Never commit the real .env (gitignored).

# Shared-password gate. When APP_PASSWORD is set, every request (except /login,
# /logout, static assets, /healthz) is redirected to /login until the visitor
# enters the shared password. Use the SAME shared password as the other apps.
# Unset/empty = gate OFF (fine for local dev).
APP_PASSWORD=

# Secret used to sign the session cookie (itsdangerous). Generate once with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# If unset while APP_PASSWORD is set, a random key is generated per boot, so
# sessions won't survive a restart — set this in prod.
SESSION_SECRET=

# Host pinning / CSRF origin pin. Set to the public hostname in prod.
APP_HOST=baby-pool.graham-williams.com
